<section
  class='max-w-2xl mx-auto bg-white rounded-2xl shadow-sm border border-slate-200 p-8'
>
  <div class='flex items-center justify-between mb-8'>
    <h2 class='text-xl font-semibold text-slate-900'>シミュレーション設定</h2>

    <span
      class='text-xs font-medium text-indigo-700 bg-indigo-50 px-3 py-1 rounded-full'
    >
      Monte Carlo
    </span>
  </div>

  <form id='sim-form' class='space-y-10'>
    <!-- 基本情報 -->
    <div>
      <h3 class='text-sm font-semibold text-slate-800 mb-4 border-b pb-2'>
        基本情報
      </h3>

      <div class='grid gap-5 sm:grid-cols-2'>
        <div class='space-y-1'>
          <label for='initial-amount' class='text-sm text-slate-600'>
            初期金額（万円）
          </label>
          <input
            id='initial-amount'
            type='number'
            min='0'
            step='1'
            value='100'
            required
            class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-200 focus:border-indigo-500'
          />
        </div>

        <div class='space-y-1'>
          <label for='monthly-contribution' class='text-sm text-slate-600'>
            毎月の積立金額（万円）
          </label>
          <input
            id='monthly-contribution'
            type='number'
            min='0'
            step='0.1'
            value='5'
            required
            class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-200 focus:border-indigo-500'
          />
        </div>

        <div class='space-y-1'>
          <label for='monthly-withdrawal' class='text-sm text-slate-600'>
            毎月の取り崩し（万円）
          </label>
          <input
            id='monthly-withdrawal'
            type='number'
            min='0'
            step='0.1'
            value='0'
            class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-200 focus:border-indigo-500'
          />
        </div>

        <div class='space-y-1'>
          <label for='years' class='text-sm text-slate-600'>
            積立期間（年）
          </label>
          <input
            id='years'
            type='number'
            min='1'
            max='50'
            value='20'
            required
            class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-200 focus:border-indigo-500'
          />
        </div>

        <div class='space-y-1 sm:col-span-2'>
          <label for='num-paths' class='text-sm text-slate-600'>
            シミュレーション回数
          </label>
          <input
            id='num-paths'
            type='number'
            min='100'
            max='5000'
            step='100'
            value='1000'
            class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-200 focus:border-indigo-500'
          />
        </div>
      </div>
    </div>

    <!-- リターン -->
    <div>
      <h3 class='text-sm font-semibold text-slate-800 mb-4 border-b pb-2'>
        想定リターン
      </h3>

      <div class='grid gap-5 sm:grid-cols-2'>
        <div class='space-y-1'>
          <label for='expected-return' class='text-sm text-slate-600'>
            期待リターン（% / 年）
          </label>
          <input
            id='expected-return'
            type='number'
            step='0.1'
            value='5'
            class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-200 focus:border-indigo-500'
          />
        </div>

        <div class='space-y-1'>
          <label for='volatility' class='text-sm text-slate-600'>
            ボラティリティ（% / 年）
          </label>
          <input
            id='volatility'
            type='number'
            step='0.1'
            value='15'
            class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-200 focus:border-indigo-500'
          />
        </div>
      </div>
    </div>

    <!-- ロック口座 -->
    <div>
      <h3 class='text-sm font-semibold text-slate-800 mb-4 border-b pb-2'>
        ロック口座（iDeCoなど）
      </h3>

      <div class='grid gap-5 sm:grid-cols-2'>
        <div class='space-y-1'>
          <label for='locked-initial' class='text-sm text-slate-600'>
            初期金額（万円）
          </label>
          <input
            id='locked-initial'
            type='number'
            value='0'
            class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
          />
        </div>

        <div class='space-y-1'>
          <label for='locked-monthly' class='text-sm text-slate-600'>
            毎月の積立（万円）
          </label>
          <input
            id='locked-monthly'
            type='number'
            step='0.1'
            value='2.3'
            class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
          />
        </div>

        <div class='space-y-1'>
          <label for='locked-years' class='text-sm text-slate-600'>
            ロック年数
          </label>
          <input
            id='locked-years'
            type='number'
            value='20'
            class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
          />
        </div>

        <div class='space-y-1'>
          <label for='locked-expected-return' class='text-sm text-slate-600'>
            期待リターン
          </label>
          <input
            id='locked-expected-return'
            type='number'
            step='0.1'
            value='4'
            class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
          />
        </div>

        <div class='space-y-1 sm:col-span-2'>
          <label for='locked-volatility' class='text-sm text-slate-600'>
            ボラティリティ
          </label>
          <input
            id='locked-volatility'
            type='number'
            step='0.1'
            value='15'
            class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
          />
        </div>
      </div>
    </div>

    <button
      type='submit'
      class='w-full rounded-lg bg-indigo-600 text-white py-3 font-semibold hover:bg-indigo-500 transition'
    >
      シミュレーション実行
    </button>
  </form>
</section>
