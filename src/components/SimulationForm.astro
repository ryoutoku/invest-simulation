<section class='bg-white rounded-2xl shadow-sm border border-slate-200 p-8'>
  <div class='mb-10'>
    <h2 class='text-xl font-semibold text-slate-900'>シミュレーション設定</h2>
    <p class='text-sm text-slate-500 mt-1'>
      投資条件を入力してモンテカルロシミュレーションを実行します
    </p>
  </div>

  <form id='sim-form' class='space-y-10'>
    <!-- 基本情報 -->
    <section class='border border-slate-200 rounded-xl p-6 bg-slate-50/40'>
      <details open>
        <summary
          class='cursor-pointer text-sm font-semibold text-slate-700 mb-6'
        >
          特定口座
        </summary>

        <div class='grid sm:grid-cols-2 gap-5'>
          <div class='space-y-1'>
            <label for='initial-amount' class='text-sm text-slate-600'>
              初期金額（万円）
            </label>
            <input
              id='initial-amount'
              type='number'
              min='0'
              step='1'
              value='100'
              required
              class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm
              focus:ring-2 focus:ring-indigo-200 focus:border-indigo-500'
            />
          </div>

          <div class='space-y-1'>
            <label for='monthly-contribution' class='text-sm text-slate-600'>
              毎月の積立（万円）
            </label>
            <input
              id='monthly-contribution'
              type='number'
              min='0'
              step='0.1'
              value='5'
              class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm
              focus:ring-2 focus:ring-indigo-200 focus:border-indigo-500'
            />
          </div>

          <div class='space-y-1'>
            <label for='monthly-withdrawal' class='text-sm text-slate-600'>
              毎月の取り崩し（万円）
            </label>
            <input
              id='monthly-withdrawal'
              type='number'
              step='0.1'
              value='0'
              class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
            />
          </div>

          <div class='space-y-1'>
            <label for='years' class='text-sm text-slate-600'>
              積立期間（年）
            </label>
            <input
              id='years'
              type='number'
              min='1'
              max='50'
              value='20'
              class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
            />
          </div>

          <div class='space-y-1'>
            <label for='expected-return' class='text-sm text-slate-600'>
              期待リターン（% / 年）
            </label>
            <input
              id='expected-return'
              type='number'
              step='0.1'
              value='5'
              class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
            />
          </div>

          <div class='space-y-1'>
            <label for='volatility' class='text-sm text-slate-600'>
              ボラティリティ（% / 年）
            </label>
            <input
              id='volatility'
              type='number'
              step='0.1'
              value='15'
              class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
            />
          </div>
        </div>
      </details>
    </section>

    <!-- iDeCo -->
    <section class='border border-slate-200 rounded-xl p-6'>
      <details open>
        <summary
          class='cursor-pointer text-sm font-semibold text-slate-700 mb-6'
        >
          ロック口座（iDeCoなど）
        </summary>

        <div class='grid sm:grid-cols-2 gap-5'>
          <div class='space-y-1'>
            <label class='text-sm text-slate-600'> 初期金額（万円） </label>
            <input
              id='locked-initial'
              type='number'
              value='0'
              class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
            />
          </div>

          <div class='space-y-1'>
            <label class='text-sm text-slate-600'> 毎月の積立（万円） </label>
            <input
              id='locked-monthly'
              type='number'
              step='0.1'
              value='2.3'
              class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
            />
          </div>

          <div class='space-y-1'>
            <label class='text-sm text-slate-600'> ロック年数 </label>
            <input
              id='locked-years'
              type='number'
              value='20'
              class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
            />
          </div>

          <div class='space-y-1'>
            <label class='text-sm text-slate-600'> 期待リターン </label>
            <input
              id='locked-expected-return'
              type='number'
              step='0.1'
              value='4'
              class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
            />
          </div>

          <div class='space-y-1 sm:col-span-2'>
            <label class='text-sm text-slate-600'> ボラティリティ </label>
            <input
              id='locked-volatility'
              type='number'
              step='0.1'
              value='15'
              class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
            />
          </div>
        </div>
      </details>
    </section>

    <!-- NISA -->
    <section class='border border-slate-200 rounded-xl p-6'>
      <details open>
        <summary
          class='cursor-pointer text-sm font-semibold text-slate-700 mb-6'
          >NISA口座</summary
        >
        <div class='grid sm:grid-cols-2 gap-5'>
          <div class='space-y-1'>
            <label class='text-sm text-slate-600'>初期金額（万円）</label>
            <input
              id='nisa-initial'
              type='number'
              value='0'
              class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
            />
          </div>

          <div class='space-y-1'>
            <label class='text-sm text-slate-600'>毎月の積立（万円）</label>
            <input
              id='nisa-monthly'
              type='number'
              step='0.1'
              value='3'
              class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
            />
          </div>

          <div class='space-y-1'>
            <label class='text-sm text-slate-600'>毎月の取り崩し（万円）</label>
            <input
              id='nisa-withdrawal'
              type='number'
              step='0.1'
              value='0'
              class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
            />
          </div>

          <div class='space-y-1'>
            <label class='text-sm text-slate-600'>期待リターン（% / 年）</label>
            <input
              id='nisa-expected-return'
              type='number'
              step='0.1'
              value='5'
              class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
            />
          </div>

          <div class='space-y-1 sm:col-span-2'>
            <label class='text-sm text-slate-600'
              >ボラティリティ（% / 年）</label
            >
            <input
              id='nisa-volatility'
              type='number'
              step='0.1'
              value='15'
              class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm'
            />
          </div>
        </div>
      </details>
    </section>

    <!-- シミュレーション -->
    <section class='space-y-4'>
      <div class='space-y-1'>
        <label for='num-paths' class='text-sm text-slate-600'>
          シミュレーション回数
        </label>
        <input
          id='num-paths'
          type='number'
          min='100'
          max='5000'
          step='100'
          value='1000'
          class='w-full rounded-lg border border-slate-300 px-3 py-2 text-sm
          focus:ring-2 focus:ring-indigo-200 focus:border-indigo-500'
        />
      </div>

      <div class='pt-4 flex justify-center'>
        <button
          type='submit'
          class='px-8 py-3 rounded-lg bg-indigo-600 text-white font-semibold
          hover:bg-indigo-500 transition shadow-sm'
        >
          シミュレーション実行
        </button>
      </div>
    </section>
  </form>
</section>
