<section class='card p-6'>
  <div class='flex items-center justify-between mb-4'>
    <h2 class='text-lg font-semibold text-slate-900'>結果</h2>
    <span
      class='inline-flex items-center rounded-full bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-700 ring-1 ring-emerald-100'
    >
      新しい予測を試す
    </span>
  </div>
  <p id='summary' class='text-sm text-slate-600 leading-relaxed mb-6'>
    パラメータを入力して「シミュレーションを実行」を押してください。
  </p>

  <div
    class='relative rounded-xl border border-slate-200 bg-white overflow-hidden mb-6'
  >
    <svg
      id='chart'
      viewBox='0 0 800 400'
      role='img'
      aria-label='投資シミュレーション結果の推移グラフ'
      class='w-full h-auto'
    >
      <defs>
        <linearGradient id='band' x1='0' y1='0' x2='0' y2='1'>
          <stop offset='0' stop-color='#4f46e5' stop-opacity='0.25'></stop>
          <stop offset='1' stop-color='#4f46e5' stop-opacity='0.02'></stop>
        </linearGradient>
      </defs>
      <rect x='0' y='0' width='800' height='400' fill='#ffffff'></rect>
      <text x='400' y='210' text-anchor='middle' fill='#9ca3af' font-size='16'>
        まだシミュレーションが実行されていません
      </text>
    </svg>
    <div id='chart-tooltip' class='chart-tooltip' hidden></div>
  </div>

  <div class='flex flex-wrap gap-4 text-xs text-slate-600 mb-4'>
    <span class='inline-flex items-center gap-2'>
      <span class='h-2 w-7 rounded-full bg-indigo-200'></span>
      中央値
    </span>
    <span class='inline-flex items-center gap-2'>
      <span
        class='h-2 w-7 rounded-full bg-gradient-to-r from-indigo-600 to-indigo-400 opacity-70'
      ></span>
      10〜90パーセンタイル
    </span>
    <span class='inline-flex items-center gap-2'>
      <span class='h-2 w-7 rounded-full bg-emerald-500'></span>
      理論値（ボラティリティなし）
    </span>
  </div>

  <h3 class='mt-6 mb-3 text-sm font-semibold text-slate-700'>
    最終時点の分布（ヒストグラム）
  </h3>
  <div
    class='relative rounded-xl border border-slate-200 bg-white overflow-hidden'
  >
    <svg
      id='histogram'
      viewBox='0 0 800 220'
      role='img'
      aria-label='最終時点の資産額分布ヒストグラム'
      class='w-full h-auto'
    >
      <rect x='0' y='0' width='800' height='220' fill='#ffffff'></rect>
      <text x='400' y='120' text-anchor='middle' fill='#9ca3af' font-size='14'>
        まだシミュレーションが実行されていません
      </text>
    </svg>
    <div id='hist-tooltip' class='chart-tooltip' hidden></div>
  </div>
</section>
